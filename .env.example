# AI — GitHub Models API (Personal Access Token with models:read scope)
GITHUB_TOKEN=ghp_your_personal_access_token_here
# GITHUB_MODEL_ID=openai/gpt-4.1

# Exchange (ccxt — 暗号資産、実取引時のみ)
EXCHANGE_ID=binance
EXCHANGE_API_KEY=your_exchange_api_key_here
EXCHANGE_SECRET=your_exchange_secret_here

# DynamoDB
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_REGION=ap-northeast-1
DYNAMODB_TABLE_NAME=InvestmentTable

# Redis
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
LOG_LEVEL=info
PAPER_TRADE=true
CONFIDENCE_THRESHOLD=0.8
MAX_ORDER_VALUE_BTC=0.001
